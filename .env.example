# Database
DATABASE_URL=postgres://alpharust:alpharust@localhost:5432/alpharust

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# LLM API Keys
# OpenRouter is used for chat completions
OPENROUTER_API_KEY=sk-or-v1-...

# Server
RUST_LOG=info
HOST=127.0.0.1
PORT=8080

# ── Milvus (Vector DB) ─────────────────────────────────────────────
# Optional: Defaults to http://localhost:19530 if not set
MILVUS_URL=http://localhost:19530

# ── Embedding model (OpenAI-compatible API) ─────────────────────────
# Any provider that implements the POST /v1/embeddings contract works:
#   OpenAI, Azure OpenAI, OpenRouter, Ollama, vLLM, LiteLLM, HuggingFace TEI, etc.
#
# Option 1: Use OpenRouter for embeddings (falls back to OPENROUTER_API_KEY if EMBEDDING_API_* not set)
EMBEDDING_MODEL=google/gemini-embedding-001
EMBEDDING_DIMENSION=3072
# EMBEDDING_API_URL and EMBEDDING_API_KEY can be omitted to use OpenRouter

# ── Chunking defaults (overridable per upload request) ──────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

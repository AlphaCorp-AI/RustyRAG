# LLM providers
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk_...

# Embeddings — local OpenAI-compatible endpoint
EMBEDDING_API_URL=http://localhost:7997/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=jinaai/jina-embeddings-v5-text-nano-retrieval
# Optional advanced fields (leave empty for TEI compatibility)
EMBEDDING_TYPE=
EMBEDDING_TASK_DOCUMENT=
EMBEDDING_TASK_QUERY=
EMBEDDING_DIMENSION=768
# Keep <= TEI --max-client-batch-size
EMBEDDING_MAX_BATCH_SIZE=16

# Server
RUST_LOG=info
HOST=127.0.0.1
PORT=8080

# ── Milvus (Vector DB) ─────────────────────────────────────────────
# Optional: Defaults to http://localhost:19530 if not set
MILVUS_URL=http://localhost:19530

# ── Chunking defaults (overridable per upload request) ──────────────
# Semantic chunking: max characters per chunk (sentence-boundary-aware)
CHUNK_SIZE=2000
# Overlap characters prepended from the previous chunk
CHUNK_OVERLAP=200

# ── Milvus index/search tuning ───────────────────────────────────────
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=256
MILVUS_SEARCH_EF=64

# ── Contextual retrieval (opt-in via ?contextual=true on upload) ─────
# LLM provider/model used to generate a context prefix per chunk
CONTEXTUAL_RETRIEVAL_PROVIDER=cerebras
CONTEXTUAL_RETRIEVAL_MODEL=gpt-oss-120b
# Max concurrent LLM calls during context generation
CONTEXTUAL_RETRIEVAL_CONCURRENCY=4
# Max document chars included per contextual prompt (overview + page window)
CONTEXTUAL_RETRIEVAL_MAX_DOC_CHARS=12000

# GPU environment overrides
# Copy to .env (or merge with existing .env) when using docker-compose.gpu.yml

# ── Server (for rustyrag web server) ──────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── LLM Providers ────────────────────────────────────────────────
CEREBRAS_API_KEY=
GROQ_API_KEY=

# ── GPU Embeddings (TEI + Jina v5) ──────────────────────────────
EMBEDDING_API_URL=http://localhost:7997/v1/embeddings
EMBEDDING_MODEL=jinaai/jina-embeddings-v5-text-small-retrieval
EMBEDDING_DIMENSION=1024
EMBEDDING_MAX_BATCH_SIZE=32

# ── Milvus GPU ──────────────────────────────────────────────────
MILVUS_URL=http://localhost:19530
MILVUS_SEARCH_EF=256

# ── Chunking (smaller = better page attribution for grounding) ──
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Contextual Retrieval (improves embedding quality) ───────────
CONTEXTUAL_RETRIEVAL_ENABLED=true
CONTEXTUAL_RETRIEVAL_PROVIDER=cerebras
CONTEXTUAL_RETRIEVAL_MODEL=llama3.1-8b
CONTEXTUAL_RETRIEVAL_CONCURRENCY=24
CONTEXTUAL_RETRIEVAL_MAX_DOC_CHARS=6000

# ── Competition (for compete binary) ────────────────────────────
EVAL_API_KEY=
EVAL_BASE_URL=https://platform.agentic-challenge.ai/api/v1
DOCS_DIR=docs_corpus
QUESTIONS_PATH=questions.json
SUBMISSION_PATH=submission.json
COLLECTION_NAME=competition
COMPETITION_MODEL=qwen-3-235b-a22b-instruct-2507
COMPETITION_PROVIDER=cerebras
COMPETITION_TOP_K=15

# Database
DATABASE_URL=postgres://alpharust:alpharust@localhost:5432/alpharust

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# LLM API Keys
OPENROUTER_API_KEY=sk-or-...

# Server
RUST_LOG=info
HOST=127.0.0.1
PORT=8080

# ── Milvus (Vector DB) ─────────────────────────────────────────────
MILVUS_URL=http://localhost:19530

# ── Embedding model (OpenAI-compatible API) ─────────────────────────
# Any provider that implements the POST /v1/embeddings contract works:
#   OpenAI, Azure OpenAI, Ollama, vLLM, LiteLLM, HuggingFace TEI, etc.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=sk-...
EMBEDDING_DIMENSION=1536

# ── Chunking defaults (overridable per upload request) ──────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

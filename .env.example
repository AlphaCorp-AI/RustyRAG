# ╔══════════════════════════════════════════════════════════════════╗
# ║  REQUIRED — the server won't start without these               ║
# ╚══════════════════════════════════════════════════════════════════╝

HOST=127.0.0.1
PORT=8080

# At least one LLM provider key is needed for chat endpoints.
# Groq key is also used for vision model (image descriptions in PDFs).
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk_...

# ╔══════════════════════════════════════════════════════════════════╗
# ║  OPTIONAL — services (defaults work with local docker-compose) ║
# ╚══════════════════════════════════════════════════════════════════╝

# Milvus vector database
# MILVUS_URL=http://localhost:19530

# Jina embeddings via TEI
# EMBEDDING_API_URL=http://localhost:7997/v1/embeddings
# EMBEDDING_MODEL=jinaai/jina-embeddings-v5-text-nano-retrieval
# EMBEDDING_API_KEY=

# TEI cross-encoder reranker (leave empty to disable reranking)
# RERANKER_API_URL=http://localhost:7998

# Docling document extraction (required for PDF/DOCX/PPTX uploads)
# DOCLING_URL=http://localhost:5001

# Vision model for describing images found inside documents
# VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ╔══════════════════════════════════════════════════════════════════╗
# ║  OPTIONAL — tuning (sensible defaults, rarely need changing)   ║
# ╚══════════════════════════════════════════════════════════════════╝

RUST_LOG=info

# CORS: comma-separated origins, empty = permissive (dev mode)
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Retrieval pipeline
# RETRIEVAL_LIMIT=20          # chunks fetched from Milvus before reranking
# RERANK_TOP_N=3              # chunks kept after reranking for LLM context
# CHUNK_SIZE=2000             # max characters per chunk (sentence-aware)
# CHUNK_OVERLAP=200           # overlap chars prepended from previous chunk

# Embedding model tuning
# EMBEDDING_DIMENSION=768
# EMBEDDING_MAX_BATCH_SIZE=64 # keep <= TEI --max-client-batch-size
# EMBEDDING_TYPE=             # leave empty for TEI compatibility
# EMBEDDING_TASK_DOCUMENT=
# EMBEDDING_TASK_QUERY=

# Milvus HNSW index tuning
# MILVUS_METRIC_TYPE=COSINE
# MILVUS_INDEX_TYPE=HNSW
# MILVUS_HNSW_M=16
# MILVUS_HNSW_EF_CONSTRUCTION=256
# MILVUS_SEARCH_EF=64

# Contextual retrieval (opt-in, costs extra LLM tokens at upload time)
# CONTEXTUAL_RETRIEVAL_ENABLED=false
# CONTEXTUAL_RETRIEVAL_PROVIDER=groq
# CONTEXTUAL_RETRIEVAL_MODEL=llama-3.1-8b-instant
# CONTEXTUAL_RETRIEVAL_CONCURRENCY=24
# CONTEXTUAL_RETRIEVAL_MAX_DOC_CHARS=6000
